{
  "name": "resume-forge",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @resumeforge/web dev",
    "build": "pnpm --filter @resumeforge/web build",
    "start": "pnpm --filter @resumeforge/web start",
    "lint": "pnpm --filter @resumeforge/web lint",
    "test": "pnpm --filter @resumeforge/web test",
    "test:watch": "pnpm --filter @resumeforge/web test:watch",
    "format": "pnpm -r --if-present format",
    "format:check": "pnpm -r --if-present format:check",
    "tauri": "pnpm --filter @resumeforge/desktop tauri",
    "tauri:dev": "pnpm --filter @resumeforge/desktop tauri:dev",
    "tauri:build": "pnpm --filter @resumeforge/desktop tauri:build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "next": "16.2.6"
  }
}
