{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl/capability.schema.json",
  "identifier": "default",
  "description": "Default capabilities for CV Tailor",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:scope",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "claude", "command": "claude", "args": true },
        { "name": "codex", "command": "codex", "args": true },
        { "name": "gemini", "command": "gemini", "args": true },
        { "name": "which", "command": "which", "args": true }
      ]
    },
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill"
  ]
}
