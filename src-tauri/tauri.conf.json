{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CV Tailor",
  "version": "0.1.0",
  "identifier": "com.cvtailor.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "node scripts/tauri-build.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "CV Tailor",
        "width": 1280,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
